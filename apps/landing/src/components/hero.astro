---
const releasesUrl = 'https://github.com/bartekczyz/claude-profiles/releases/latest'
const repoUrl = 'https://github.com/bartekczyz/claude-profiles'
---
<section class="mx-auto max-w-[760px] px-6 pt-[72px] pb-9 text-center">
  <h1 class="m-0 text-[40px] font-semibold leading-[1.12] tracking-[-0.022em]">
    Switch Claude accounts on macOS without logging out.
  </h1>
  <p class="mx-auto mb-7 mt-[18px] max-w-[580px] text-[17px] leading-[1.55] text-ink-soft">
    claude-profiles lets you keep multiple Claude accounts side by side — the desktop app and the Claude Code CLI both. Free, open-source, local-only.
  </p>
  <div class="mb-[14px] flex items-center justify-center gap-3">
    <a
      id="download-cta"
      href={releasesUrl}
      class="inline-flex items-center gap-2 rounded-lg bg-orange px-[18px] py-[11px] text-[13.5px] font-medium text-white shadow-button-primary"
    >
      Download for macOS
    </a>
    <a
      href={repoUrl}
      class="inline-flex items-center gap-2 rounded-lg border border-border-strong px-4 py-[10px] text-[13.5px] text-ink"
    >
      View on GitHub
    </a>
  </div>
  <p id="fineprint" class="font-mono text-[11.5px] text-muted">macOS 12+  ·  18 MB  ·  MIT</p>
</section>
