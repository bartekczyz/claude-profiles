---
const launchers = [
  {
    name: 'Personal',
    ring: 'var(--color-profile-orange)',
    gradient: 'linear-gradient(155deg, #E89F6B, var(--color-profile-orange))',
  },
  {
    name: 'Work',
    ring: 'var(--color-profile-steel)',
    gradient: 'linear-gradient(155deg, #87A6C8, var(--color-profile-steel))',
  },
  {
    name: 'Acme Co.',
    ring: 'var(--color-profile-sage)',
    gradient: 'linear-gradient(155deg, #98B58A, var(--color-profile-sage))',
  },
  {
    name: 'Side Project',
    ring: 'var(--color-profile-amber)',
    gradient: 'linear-gradient(155deg, #D8B66B, var(--color-profile-amber))',
  },
  {
    name: 'Research',
    ring: 'var(--color-profile-rose)',
    gradient: 'linear-gradient(155deg, #DA9696, var(--color-profile-rose))',
  },
]
---
<div class="mx-auto max-w-[800px] px-4 pt-4 sm:px-14" aria-hidden="true">
  <div class="overflow-hidden rounded-xl border border-border-strong shadow-window">
    <!-- Title bar — gradient uses CSS vars so it adapts to dark theme -->
    <div
      class="flex items-center gap-2 border-b border-border px-[14px] py-[9px]"
      style="background: linear-gradient(to bottom, var(--color-cream-3), var(--color-base));"
    >
      <div class="flex gap-1.5">
        <span class="size-[11px] rounded-full bg-[#ED6A5F]"></span>
        <span class="size-[11px] rounded-full bg-[#F4BE4F]"></span>
        <span class="size-[11px] rounded-full bg-[#61C554]"></span>
      </div>
      <div class="mx-auto pr-14 text-[12.5px] font-medium text-muted">Applications</div>
    </div>
    <!-- Path bar -->
    <div class="border-b border-border bg-cream px-[14px] py-1.5 font-mono text-[11.5px] text-muted">
      ~/Applications
    </div>
    <!-- Icon grid — bg-cream adapts to dark via CSS variables -->
    <div class="grid grid-cols-1 gap-1.5 bg-cream px-[18px] py-6 sm:grid-cols-5">
      {launchers.map(({ name, ring, gradient }) => (
        <div class="flex flex-col items-center gap-[7px] rounded-lg px-2 py-2.5">
          <div
            class="relative grid size-[54px] place-items-center rounded-[13px] text-2xl font-semibold text-white"
            style={`background: ${gradient}; box-shadow: 0 4px 10px -4px rgba(40,30,20,0.25), inset 0 1px 0 rgba(255,255,255,0.3);`}
          >
            C
            <span class="pointer-events-none absolute -inset-[3px] rounded-[16px] opacity-[0.65]" style={`border: 2px solid ${ring};`}></span>
          </div>
          <span class="text-center text-[10.5px] leading-[1.3] text-ink">
            Claude<span class="block text-[10px] text-muted">({name})</span>
          </span>
        </div>
      ))}
    </div>
  </div>
</div>
