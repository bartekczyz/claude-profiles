---
import { defaultDmgFilename } from '../lib/version'

interface Row {
  id: string
  label: string
  cmd: string
  kind: 'download' | 'command'
}

const rows: ReadonlyArray<Row> = [
  { id: 'install-download', label: 'Direct download', cmd: defaultDmgFilename, kind: 'download' },
  {
    id: 'install-homebrew',
    label: 'Homebrew (coming soon)',
    cmd: 'brew install --cask claude-profiles',
    kind: 'command',
  },
  {
    id: 'install-source',
    label: 'Build from source',
    cmd: 'git clone https://github.com/bartekczyz/claude-profiles',
    kind: 'command',
  },
]
---
<section id="download" aria-labelledby="install-heading" class="mx-auto max-w-[680px] px-4 pt-8 pb-4 sm:px-14">
  <h2 id="install-heading" class="m-0 mb-[18px] text-[22px] font-semibold tracking-[-0.014em]">Install</h2>
  {rows.map(({ id, label, cmd, kind }) => (
    <div class="mb-4">
      <p class="mb-1.5 text-[13px] text-muted">{label}</p>
      <div class="flex items-center justify-between rounded-lg border border-border bg-cream-2 px-[14px] py-[11px] font-mono text-[12.5px] text-ink">
        <span data-install-cmd={id}>{cmd}</span>
        {kind === 'download' ? (
          <a
            id="install-download-link"
            href="https://github.com/bartekczyz/claude-profiles/releases/latest"
            aria-label={`Download ${cmd}`}
            class="cursor-pointer text-[11px] text-orange-deep hover:text-orange"
          >
            download
          </a>
        ) : (
          <button
            type="button"
            data-copy-target={id}
            aria-label={`Copy ${label} command`}
            class="cursor-pointer text-[11px] text-muted hover:text-ink"
          >
            copy
          </button>
        )}
      </div>
    </div>
  ))}
</section>

<script is:inline>
  const restingLabel = 'copy'
  const copiedLabel = 'copied'
  const resetAfterMs = 1400

  for (const button of document.querySelectorAll('[data-copy-target]')) {
    let resetTimeout = 0
    button.addEventListener('click', async () => {
      const target = button.getAttribute('data-copy-target')
      const cmdEl = document.querySelector(`[data-install-cmd="${target}"]`)
      if (!cmdEl) {
        return
      }
      try {
        await navigator.clipboard.writeText(cmdEl.textContent ?? '')
        button.textContent = copiedLabel
        window.clearTimeout(resetTimeout)
        resetTimeout = window.setTimeout(() => { button.textContent = restingLabel }, resetAfterMs)
        window.dispatchEvent(new CustomEvent('install:copy', { detail: { target } }))
      } catch (error) {
        // Clipboard API not available; silently no-op.
      }
    })
  }
</script>
